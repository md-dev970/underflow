{
  "name": "underflow-api",
  "version": "0.1.0",
  "description": "Underflow production-style API backend",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "jobs": "tsx src/jobs/worker.ts",
    "migrate": "tsx src/db/migrate.ts",
    "seed:demo": "node src/scripts/seed-demo.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/jobs/worker.js",
    "start:migrate": "node dist/db/migrate.js",
    "test": "tsx --test src/**/*.test.ts",
    "test:watch": "tsx watch --test src/**/*.test.ts",
    "test:db": "tsx --test --test-concurrency=1 src/test/*.integration.spec.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cost-explorer": "^3.901.0",
    "@aws-sdk/client-ses": "^3.901.0",
    "@aws-sdk/client-sts": "^3.901.0",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.12.0",
    "stripe": "^16.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2"
  }
}
