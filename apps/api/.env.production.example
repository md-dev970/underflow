PORT=3080
NODE_ENV=production
DATABASE_URL=postgresql://underflow:change_me@underflow-prod-db.example.amazonaws.com:5432/underflow
DATABASE_SSL_ENABLED=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
CSRF_SECRET=change_me_csrf
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://underflow.example.com/billing/success
STRIPE_CANCEL_URL=https://underflow.example.com/billing/cancel
AWS_REGION=us-west-2
COST_SYNC_LOOKBACK_DAYS=30
EMAIL_PROVIDER=ses
ALERT_EMAIL_FROM=alerts@underflow.example.com
AUTH_EMAIL_FROM=auth@underflow.example.com
PASSWORD_RESET_EXPIRES_IN_MINUTES=60
AWS_SES_REGION=us-west-2
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
BILLING_ENABLED=false
CLIENT_URL=https://underflow.example.com
AUTH_COOKIE_DOMAIN=underflow.example.com
AUTH_COOKIE_SAME_SITE=lax
LOG_LEVEL=info
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX_REQUESTS=10
RATE_LIMIT_MUTATION_WINDOW_MS=60000
RATE_LIMIT_MUTATION_MAX_REQUESTS=20
